{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "object",
    "properties": {
        "numeroAtaRegistroPreco": {
            "type": "string",
            "minLength":1,
            "maxLength":50
        },
        "anoAta": {
            "type": "integer"
        },
        "dataAssinatura": {
            "type": "string"
        },
        "dataVigenciaInicio": {
            "type": "string"
        },
        "dataVigenciaFim": {
            "type": "string"
        },
        "possibilidadeAdesao": {
            "type": "boolean"
        },
        "partesEnvolvidas": {
          "type": "array",
          "items": {
            "type": "array",
            "properties": {
              "tipoParteEnvolvidaId": {
                "type": "integer",
                "enum": [1, 2, 3]
              },
              "cnpj": {
                "type": "string",
                "minLength": 14,
                "maxLength": 14
              },
              "codigoUnidadeCompradora": {
                "type": "string",
                "minLength": 1,
                "maxLength": 30
              }
            }
          }
        }   
    },
    "required": [
        "numeroAtaRegistroPreco",
        "anoAta",
        "dataAssinatura",
        "dataVigenciaInicio",
        "dataVigenciaFim",
        "possibilidadeAdesao"
    ],
    "dependencies": {
      "partesEnvolvidas": ["possibilidadeAdesao"]
    }
}